# ── Partners in Crime — Environment Config ──────────────────────

# LLM Provider: "claude" (Anthropic API) or "ollama" (local)
LLM_PROVIDER=claude

# Anthropic API (when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
SPECIALIST_MODEL=claude-sonnet-4-20250514
ORCHESTRATOR_MODEL=claude-haiku-4-5-20251001

# Ollama (when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# Context / token settings
NUM_CTX=16384
OLLAMA_KEEP_ALIVE=120s
# Cooldown between LLM calls — 0 for Claude (API is fast), 2.0 for Ollama (VRAM settling)
LLM_COOLDOWN=0

# RAG retrieval limits (fewer = less embedding pressure on GPU)
RAG_CODEBASE_K=2
RAG_MISTAKES_K=2
RAG_RESULTS_K=2

# Paths — set PROJECT_ROOT to the directory your agents will build in
PROJECT_ROOT=c:/Users/User/Desktop/your-project
CHROMADB_PATH=./chromadb_data
OUTPUT_DIR=./output

# Reference project: agents can read files from v1 codebase (read-only)
REFERENCE_PROJECT_ROOT=

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Agent behavior
MAX_RETRIES=2
COMMAND_TIMEOUT=60
MAX_FILE_READ_BYTES=1048576
MAX_COMMAND_OUTPUT=2000

# Agentic execution — how many tool call rounds each agent gets
MAX_TOOL_ITERATIONS=40
# Max chars kept from each tool result (saves context window space)
MAX_TOOL_RESULT_CHARS=3000

# Build verification: auto-run build check after agent calls task_done
BUILD_VERIFY_ENABLED=true
BUILD_VERIFY_MAX_RETRIES=2

# Safety: allowed commands
ALLOWED_COMMANDS=python,pip,pytest,npm,npx,node,tsc,git,ls,dir,cat,type,echo,mkdir,cd,rm,cp,mv
